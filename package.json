{
  "name": "@arke-institute/scatter",
  "version": "1.0.0",
  "description": "Scatter utility klados - receives entity IDs and scatters to next workflow step",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "type-check": "tsc --noEmit",
    "register": "npx tsx scripts/register.ts",
    "register:prod": "npx tsx scripts/register.ts --production",
