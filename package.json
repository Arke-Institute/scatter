    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@arke-institute/klados-testing": "^0.4.1",
    "@cloudflare/workers-types": "^4.20241230.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.0.0",
    "wrangler": "^3.99.0"
  }
}
